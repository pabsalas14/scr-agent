    "jsdom": "^29.0.1",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "postcss": "^8.4.32",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.1",
