    "@types/sanitize-html": "^2.9.5",
    "@types/validator": "^13.11.8",
    "prisma": "^5.8.0",
    "supertest": "^6.3.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
