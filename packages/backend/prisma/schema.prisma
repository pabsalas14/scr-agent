// Esquema de base de datos PostgreSQL para SCR Agent
//
// Estructura de datos:
// - Proyectos: Repositorios a analizar
// - Análisis: Ejecuciones de análisis completo
// - Hallazgos: Resultados del Agente Inspector
// - Eventos Forenses: Timeline de cambios del Agente Detective
// - Reportes: Síntesis final del Agente Fiscal

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ==================== MODELOS BASE ====================

// Usuario - Autenticación y autorización
model User {
  id           String   @id @default(cuid())
  email        String   @unique @db.VarChar(255)
  name         String?  @db.VarChar(255)
  avatar       String?  @db.VarChar(500)
  bio          String?  @db.VarChar(500)
  passwordHash String   @db.VarChar(255)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  settings     UserSettings?
  roles        UserRole[]
  projects     Project[]
  assignments  FindingAssignment[]
  statusChanges FindingStatusChange[]
  findingAudits FindingAudit[]
  notifications Notification[]
  comments     Comment[]
  mentionedIn  CommentMention[] @relation("CommentMentions")
  notificationPreferences NotificationPreferences?
  auditLogs    AuditLog[]
  remediationActions RemediationAction[] @relation("remediationActions") // Phase 1 - asignaciones de remediación
  remediationComments RemediationComment[]
  tokenUsage   TokenUsage[] // Track token consumption per analysis

  @@index([email])
  @@map("users")
}

// Rol del usuario - Para RBAC
model UserRole {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        Role     @default(VIEWER)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, role])
  @@index([userId])
  @@index([role])
  @@map("user_roles")
}

// Configuraciones del Usuario
model UserSettings {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // GitHub token (encriptado en BD)
  githubToken   String?  @db.VarChar(500)
  githubValidatedAt DateTime?

  // Claude API Key (encriptado en BD)
  claudeApiKey  String?  @db.VarChar(500)

  // Configuración de IA
  selectedModel   String?  @default("claude-sonnet-4-6") @db.VarChar(100)
  temperature     Float?   @default(0.7)
  maxTokens       Int?     @default(4096)
  webhookUrl      String?  @db.VarChar(500)

  // LLM Provider Configuration (encriptado en BD)
  llmProvider      String?  @default("anthropic") @db.VarChar(50) // anthropic, openai, lmstudio, ollama, llm-gateway, openai-compatible, custom
  llmBaseUrl       String?  @db.VarChar(500) // URL base para servidores (ej: http://localhost:1234/v1, https://api.openai.com/v1)
  llmModel         String?  @db.VarChar(100) // Modelo específico (ej: qwen2.5-coder-7b-instruct, gpt-4)
  llmApiKey        String?  @db.VarChar(500) // API Key cifrada (para Anthropic, OpenAI, LLM Gateway)
  llmCustomHeaders String?  @db.Text // JSON con headers personalizados para LLM Gateway/Custom

  // PHASE 3.4: Per-agent LLM configuration
  agentLLMConfig   String?  @db.Text // JSON: { inspector: { provider, model, apiKey }, detective: {...}, fiscal: {...} }

  // PHASE 3.4: Code sanitization settings
  sanitizeCode     Boolean  @default(true)  // Enable code sanitization before LLM
  maskSecrets      Boolean  @default(true)  // Mask API keys, passwords, tokens
  anonimizeNames   Boolean  @default(false) // Anonymize variable and function names

  // API Key para servicios externos
  apiKey        String?  @db.VarChar(500)

  // Preferencias
  darkMode      Boolean  @default(false)
  autoRefresh   Int      @default(10000) // ms

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@map("user_settings")
}

// Configuración global del sistema (allowlists, hardening, etc.)
model SystemSetting {
  key       String   @id @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// Proyecto - Repositorio a ser analizado
// Soporta: GitHub, GitLab, Bitbucket
model Project {
  id            String  @id @default(cuid())
  name          String  @db.VarChar(255)
  description   String?
  repositoryUrl String  @unique @db.VarChar(500)
  branch        String? @default("main") @db.VarChar(255)

  // Configuración de alcance
  scope AnalysisScope @default(REPOSITORY)

  // Token para repositorios privados (encriptado en BD)
  githubToken String? @db.VarChar(500)

  // Metadata del repositorio
  isPublic       Boolean @default(false)  // True si es público y no requiere token
  availableBranches String[] @default([]) // JSON array de ramas disponibles

  // Límites de análisis configurables por proyecto
  maxFileSizeKb     Int @default(150)
  maxTotalSizeMb    Int @default(2)
  maxDirectoryDepth Int @default(6)
  maxCommits        Int @default(50)

  // Propietario del proyecto
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  analyses Analysis[]

  @@index([repositoryUrl])
  @@index([userId])
  @@map("projects")
}

// Análisis - Ejecución completa del flujo SCR
// Contiene: Inspector findings → Detective timeline → Fiscal report
model Analysis {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Estado de análisis
  status   AnalysisStatus @default(PENDING)
  progress Int            @default(0) // 0-100
  errorMessage String? @db.Text // Mensaje de error si el análisis falla

  // Datos
  findings       Finding[]
  forensicEvents ForensicEvent[]
  report         Report?

  // Resumen de cobertura: cuánto código quedó fuera del análisis
  coverageSummary Json?

  // Job tracking (Phase 1)
  job AnalysisJob?

  // Incremental analysis tracking (Phase 1)
  lastCommitProcessed String? // SHA del último commit analizado (para análisis incrementales)

  // Timing
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([projectId, status])
  @@index([status])
  @@map("analyses")
}

// ==================== AGENTE INSPECTOR ====================

// Hallazgo - Resultado del análisis de código malicioso
// Generado por: Agente Inspector (Claude 3.5 Sonnet)
model Finding {
  id         String   @id @default(cuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Ubicación en código
  file      String  @db.VarChar(500)
  function  String? @db.VarChar(255)
  lineRange String // "45-52" en formato string para flexibilidad

  // Análisis de riesgo
  severity   Severity @default(MEDIUM)
  riskType   RiskType
  confidence Float    @default(0.5) // 0.0-1.0

  // Contenido
  codeSnippet      String?  @db.Text
  whySuspicious    String   @db.Text
  remediationSteps String[]

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // BUG FIX #10: Soft deletes - prevent data loss from cascade deletes
  deletedAt DateTime?

  // Lifecycle timestamps (PHASE 3)
  correctionTime   DateTime?  // When marked as CORRECTED
  verificationTime DateTime?  // When marked as VERIFIED
  closedAt         DateTime?  // When marked as CLOSED
  mttc             Int?       // Mean Time To Correction (milliseconds)

  // Relaciones
  forensicEvents ForensicEvent[]
  assignment FindingAssignment?
  statusHistory FindingStatusChange[]
  auditTrail FindingAudit[]
  remediation RemediationEntry?
  remediationAction RemediationAction? // Phase 1
  comments Comment[]
  notifications Notification[]

  // Índices (mejorados con soft deletes)
  @@index([analysisId, severity])
  @@index([analysisId, deletedAt])  // Para queries que filtran por no eliminados
  @@index([analysisId, createdAt])  // BUG FIX #9: Para timeline queries que ordenan por fecha
  @@index([analysisId])
  @@index([severity])
  @@index([riskType])
  @@map("findings")
}

// Asignación de hallazgo a usuario
model FindingAssignment {
  id        String   @id @default(cuid())
  findingId String   @unique
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)

  assignedTo String
  assignedUser User @relation(fields: [assignedTo], references: [id], onDelete: SetNull)

  assignedAt DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([findingId])
  @@index([assignedTo])
  @@map("finding_assignments")
}

// Estado actual del hallazgo
model FindingStatusChange {
  id        String   @id @default(cuid())
  findingId String
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)

  status    FindingStatus
  changedBy String
  changedByUser User @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  note      String?  @db.Text
  createdAt DateTime @default(now())

  @@index([findingId])
  @@index([status])
  @@index([createdAt])
  @@map("finding_status_changes")
}

// Finding Audit Trail - Complete lifecycle tracking (PHASE 3)
model FindingAudit {
  id        String   @id @default(cuid())
  findingId String
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)

  // Who made the change
  changedBy String
  changedByUser User @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  // What changed
  action    String   @db.VarChar(100)  // 'STATUS_CHANGE', 'ASSIGNMENT', 'COMMENT', 'REMEDIATION_UPDATE'
  oldValue  String?  @db.Text          // Previous value (for status, severity, etc)
  newValue  String?  @db.Text          // New value
  comment   String?  @db.Text          // Additional notes from the user

  // Metadata
  createdAt DateTime @default(now())

  @@index([findingId])
  @@index([changedBy])
  @@index([action])
  @@index([createdAt])
  @@map("finding_audits")
}

// Entrada de remediación (legacy - deprecated en Phase 1)
model RemediationEntry {
  id        String   @id @default(cuid())
  findingId String   @unique
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)

  // Detalles de corrección
  correctionNotes String? @db.Text
  proofOfFixUrl   String? @db.VarChar(500)  // PR link, commit, screenshot, etc
  status          RemediationStatus @default(PENDING)

  // Verificación
  verifiedAt      DateTime?
  verificationNotes String? @db.Text

  // Timing
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([findingId])
  @@index([status])
  @@map("remediation_entries")
}

// ==================== PHASE 1: REMEDIATION TRACKING ====================

/// RemediationAction - Seguimiento de remediación de hallazgos
/// Sistema mejorado para registrar fixes y validarlos
model RemediationAction {
  id           String   @id @default(cuid())
  findingId    String
  finding      Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)

  // Estado
  status       RemediationStatus @default(PENDING) // pending, in_progress, completed, verified, rejected
  assigneeId   String?
  assignee     User?    @relation(fields: [assigneeId], references: [id], onDelete: SetNull, name: "remediationActions")

  // Detalles
  title        String?  @db.VarChar(255)
  description  String?  @db.Text
  dueDate      DateTime?
  priority     Int      @default(0) // 0=normal, 1=high, 2=critical

  // Evidencia de fix
  evidence     Json? // {commitSha, prUrl, description, verifiedAt}
  comment      String?  @db.Text

  // Timing
  startedAt    DateTime?
  completedAt  DateTime?
  verifiedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  comments     RemediationComment[]

  @@unique([findingId])
  @@index([status, dueDate])
  @@index([assigneeId])
  @@map("remediation_actions")
}

/// RemediationComment - Comentarios en remediación
model RemediationComment {
  id              String   @id @default(cuid())
  remediationId   String
  remediation     RemediationAction @relation(fields: [remediationId], references: [id], onDelete: Cascade)

  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  content         String   @db.Text
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([remediationId, createdAt])
  @@index([userId])
  @@map("remediation_comments")
}

// ==================== AGENTE DETECTIVE ====================

// EventoForense - Evento en la línea de tiempo de Git
// Generado por: Agente Detective (Claude 3.5 Haiku)
model ForensicEvent {
  id         String   @id @default(cuid())
  analysisId String
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Relacionado con hallazgo
  findingId String?
  finding   Finding? @relation(fields: [findingId], references: [id], onDelete: SetNull)

  // Datos de commit
  commitHash    String @db.VarChar(40)
  commitMessage String @db.Text
  author        String @db.VarChar(255)

  // Cambios
  action         GitAction
  file           String    @db.VarChar(500)
  function       String?   @db.VarChar(255)
  changesSummary String?   @db.Text

  // Evaluación de riesgo
  riskLevel           Severity @default(LOW)
  suspicionIndicators String[]

  // Temporal
  timestamp DateTime

  // Metadata
  createdAt DateTime @default(now())

  @@index([analysisId])
  @@index([timestamp])
  @@index([author])
  @@map("forensic_events")
}

// ==================== AGENTE FISCAL ====================

// Reporte - Síntesis final con recomendaciones
// Generado por: Agente Fiscal (Claude 3.5 Sonnet)
model Report {
  id         String   @id @default(cuid())
  analysisId String   @unique
  analysis   Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Resumen ejecutivo
  executiveSummary String @db.Text
  riskScore        Int // 0-100

  // Desglose
  findingsCount        Int
  severityBreakdown    Json
  compromisedFunctions String[]
  affectedAuthors      String[]

  // Metadata de ejecución (Costos)
  inputTokens  Int    @default(0)
  outputTokens Int    @default(0)
  model        String @default("claude-3-5-sonnet")

  // Remediación
  remediationSteps      Json
  generalRecommendation String @db.Text

  // Exportación
  jsonContent String? @db.Text

  // Metadata
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("reports")
}

// ==================== ENUMS ====================

/// Alcance del análisis
enum AnalysisScope {
  REPOSITORY // Analizar repositorio completo
  ORGANIZATION // Analizar toda la organización
  PULL_REQUEST // Analizar solo cambios en PR
}

/// Estado del análisis
enum AnalysisStatus {
  PENDING // Pendiente de ejecución
  RUNNING // Ejecutándose
  INSPECTOR_RUNNING // Agente Inspector en proceso
  DETECTIVE_RUNNING // Agente Detective en proceso
  FISCAL_RUNNING // Agente Fiscal en proceso
  PAUSED // Pausado por el usuario (cola interrumpida, reanudable)
  COMPLETED // Análisis completado
  FAILED // Falló el análisis
  CANCELLED // Cancelado por el usuario
  PARTIAL // Completado parcialmente
  ERROR // Legacy: presente en migración inicial; preferir FAILED en lógica nueva
}

/// Severidad de hallazgo
enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// Tipo de riesgo detectado
enum RiskType {
  BACKDOOR // Puerta trasera
  INJECTION // Inyección de código
  LOGIC_BOMB // Bomba lógica
  OBFUSCATION // Código ofuscado
  SUSPICIOUS // Comportamiento sospechoso
  ERROR_HANDLING // Manejo de errores anormal
  HARDCODED_VALUES // Valores hardcodeados
}

/// Acción de Git
enum GitAction {
  ADDED // Archivo/función agregada
  MODIFIED // Archivo/función modificada
  DELETED // Archivo/función eliminada
  RENAMED // Archivo renombrado
}

// ==================== PHASE 1: TRACKING & MULTI-USER ====================

/// Rol de usuario
enum Role {
  ADMIN // Acceso total
  ANALYST // Analista de seguridad
  DEVELOPER // Desarrollador
  VIEWER // Solo lectura
}

/// Estado del hallazgo
enum FindingStatus {
  DETECTED // Hallazgo detectado
  IN_REVIEW // En revisión por equipo
  IN_CORRECTION // En proceso de corrección
  CORRECTED // Corregido por desarrollador
  VERIFIED // Verificado por analista
  FALSE_POSITIVE // Falso positivo
  CLOSED // Cerrado
}

/// Estado de remediación
enum RemediationStatus {
  PENDING // Pendiente de inicio
  IN_PROGRESS // En progreso
  COMPLETED // Completado
  VERIFIED // Verificado
  REJECTED // Rechazado por QA
}

// ==================== PHASE 4: REAL-TIME & COLLABORATION ====================

/// Notificación - Para sistema de notificaciones en tiempo real
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      NotificationType
  title     String
  message   String   @db.Text
  severity  NotificationSeverity @default(INFO)

  // Relación opcional a hallazgo
  findingId String?
  finding   Finding? @relation(fields: [findingId], references: [id], onDelete: SetNull)

  // Datos adicionales
  metadata  Json?
  read      Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([read])
  @@index([createdAt])
  @@map("notifications")
}

/// Comentario - Para discusiones en hallazgos
model Comment {
  id        String   @id @default(cuid())
  findingId String
  finding   Finding  @relation(fields: [findingId], references: [id], onDelete: Cascade)

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: SetNull)

  content   String   @db.Text
  mentions  String[] @default([]) // ["@user1", "@user2"]

  // Relaciones
  mentionNotifications CommentMention[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([findingId])
  @@index([userId])
  @@index([createdAt])
  @@map("comments")
}

// Notificación de mención en comentario
model CommentMention {
  id        String   @id @default(cuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)

  mentionedUserId String
  mentionedUser   User     @relation("CommentMentions", fields: [mentionedUserId], references: [id], onDelete: Cascade)

  read      Boolean  @default(false)
  readAt    DateTime?

  createdAt DateTime @default(now())

  @@index([commentId])
  @@index([mentionedUserId])
  @@index([read])
  @@map("comment_mentions")
}

// Agregar relación de mentions en User
// Nota: User modelo ya tiene comments: Comment[]
// Necesitamos agregar: mentionedIn CommentMention[]

/// Preferencias de notificación del usuario
model NotificationPreferences {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Tipos de notificación habilitados
  enableAssignments      Boolean @default(true)
  enableStatusChanges    Boolean @default(true)
  enableRemediations     Boolean @default(true)
  enableComments         Boolean @default(true)
  enableDigestEmail      Boolean @default(false)

  // Configuración
  digestFrequency        String  @default("DAILY") // DAILY, WEEKLY, NEVER
  emailNotifications     Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@map("notification_preferences")
}

// ==================== PHASE 1: JOB QUEUE TRACKING ====================

/// AuditLog - Registro de auditoría de acciones en el sistema
/// Trazabilidad: quién hizo qué cuándo
model AuditLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Acción realizada
  action        String   @db.VarChar(50) // create, update, delete, run, cancel, etc
  resourceType  String   @db.VarChar(50) // analysis, finding, project, etc
  resourceId    String?  @db.VarChar(255)

  // Detalles
  details       Json? // información adicional sobre la acción
  ipAddress     String?  @db.VarChar(45)
  userAgent     String?  @db.Text

  // Timing
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, resourceType, createdAt])
  @@index([resourceType, resourceId])
  @@map("audit_logs")
}

/// AnalysisJob - Seguimiento de jobs en Bull queue
/// Para procesamiento concurrente y recuperación tras fallos
model AnalysisJob {
  id           String   @id @default(cuid())
  analysisId   String
  analysis     Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  // Job status
  bullJobId    String   @unique // ID del job en Bull/Redis
  status       JobStatus @default(PENDING) // pending, active, completed, failed, delayed
  priority     Int       @default(0) // 0=normal, 1=high

  // Error tracking
  attempts     Int       @default(0)
  maxAttempts  Int       @default(3)
  lastError    String?   @db.Text
  nextRetryAt  DateTime?

  // Timing
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([analysisId])
  @@index([status, priority, createdAt])
  @@index([status])
  @@index([bullJobId])
  @@map("analysis_jobs")
}

// ==================== WEBHOOKS ====================

model Webhook {
  id           String   @id @default(cuid())
  url          String   @db.VarChar(500)
  events       String[] // JSON array stored as text: ['finding.created', 'finding.updated']
  status       String   @default("active") // 'active' or 'inactive'
  secret       String?  @db.VarChar(255)
  headers      String?  @db.Text // Custom headers as JSON

  // Timing
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  lastDelivery DateTime?

  @@index([status, createdAt])
  @@map("webhooks")
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  webhookId    String   @db.VarChar(255)
  event        String   @db.VarChar(100)
  payload      String   @db.Text
  status       String   // 'pending', 'success', 'failed'
  statusCode   Int?
  error        String?  @db.Text
  attempts     Int      @default(0)

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([webhookId, createdAt])
  @@index([status, createdAt])
  @@map("webhook_deliveries")
}

// Agent Prompt Customization (PHASE 2)
model AgentPrompt {
  id           String   @id @default(cuid())
  agentName    String   @unique @db.VarChar(50)  // inspector, detective, fiscal
  prompt       String   @db.Text                  // The custom prompt/context
  version      Int      @default(1)               // Version number

  // Agent model configuration (PHASE 2.1)
  model        String?  @db.VarChar(100)         // claude-sonnet-4-6, qwen2.5-coder-7b, etc
  provider     String?  @db.VarChar(50)          // anthropic, lmstudio, ollama, etc

  updatedBy    String?  @db.VarChar(255)          // User who last updated
  updatedAt    DateTime @updatedAt

  createdAt    DateTime @default(now())

  @@map("agent_prompts")
}

// Alert Rules - Trigger system (PHASE 2.5)
model AlertRule {
  id                   String   @id @default(cuid())
  userId               String   @db.VarChar(255)
  name                 String   @db.VarChar(255)
  description          String?  @db.Text

  // Trigger conditions
  severityThreshold    String   @db.VarChar(50)   // CRITICAL, HIGH, MEDIUM, LOW
  findingCountMin      Int      @default(1)       // Minimum number of findings to trigger
  findingCountMax      Int?                        // Maximum number of findings to trigger (null = no limit)
  riskTypeFilter       String?  @db.Text          // JSON array of risk types (null = all)
  filePatternFilter    String?  @db.VarChar(500)  // Regex pattern for files (null = all)

  // Trigger actions
  notificationChannel  String   @db.VarChar(100)  // 'webhook', 'email', 'slack', 'in_app'
  webhookUrl           String?  @db.VarChar(500)  // For webhook channel
  enabled              Boolean  @default(true)

  // Metadata
  triggeredCount       Int      @default(0)       // How many times this rule has triggered
  lastTriggeredAt      DateTime?                  // When it last triggered
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([userId])
  @@index([enabled])
  @@index([severityThreshold])
  @@map("alert_rules")
}

// Alert Triggers - Log of when rules trigger (PHASE 2.5)
model AlertTrigger {
  id               String   @id @default(cuid())
  ruleId           String   @db.VarChar(255)
  ruleId_actual    String   @db.VarChar(255)      // FK to AlertRule.id
  findingIds       String   @db.Text              // JSON array of finding IDs that triggered
  status           String   @db.VarChar(50)       // TRIGGERED, DELIVERED, FAILED
  errorMessage     String?  @db.Text

  createdAt        DateTime @default(now())

  @@index([ruleId_actual, createdAt])
  @@index([status])
  @@map("alert_triggers")
}

// ==================== ENUMS: PHASE 4 ====================

/// Tipo de notificación
enum NotificationType {
  STATUS_CHANGE       // Cambio de estado de hallazgo
  ASSIGNMENT          // Asignación de hallazgo
  REMEDIATION         // Actualización de remediación
  VERIFICATION        // Verificación de remediación
  COMMENT             // Nuevo comentario
  SYSTEM              // Notificación del sistema
}

/// Severidad de notificación
enum NotificationSeverity {
  INFO
  SUCCESS
  WARNING
  ERROR
}

// ==================== PHASE 3: METRICS & ANALYTICS ====================

/// TokenUsage - Tracking de consumo de tokens por usuario
/// Para análisis de costos y monitoreo de uso
model TokenUsage {
  id            String   @id @default(cuid())
  analysisId    String   @db.VarChar(255)
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Token counts
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)

  // Model information
  model         String   @db.VarChar(100)   // claude-sonnet-4-6, gpt-4, qwen2.5, etc
  provider      String   @db.VarChar(50)    // anthropic, openai, lmstudio, ollama

  // Cost calculation (if applicable)
  costUsd       Float?   @default(0)

  // Metadata
  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([analysisId])
  @@index([provider])
  @@map("token_usage")
}

// ==================== ENUMS: PHASE 1 ====================

/// Estado de job en Bull queue
enum JobStatus {
  PENDING      // Esperando ser procesado
  QUEUED       // En cola Bull, pendiente de worker
  ACTIVE       // Actualmente siendo procesado
  COMPLETED    // Completado exitosamente
  FAILED       // Falló después de todos los reintentos
  DELAYED      // Esperando retry después de fallo
}
