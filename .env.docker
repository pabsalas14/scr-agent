# ═════════════════════════════════════════════
# Docker Environment Variables
# ═════════════════════════════════════════════

# Database
POSTGRES_USER=scr
POSTGRES_PASSWORD=scr_secret
POSTGRES_DB=scr_agent

# Backend
NODE_ENV=production
# Mín. 32 caracteres (exigido en producción por validate-env)
JWT_SECRET=your-secret-jwt-key-change-this-min-32
ENCRYPTION_KEY=abcdef0123456789abcdef0123456789abcdef0123456789abcdef0123456789
ANTHROPIC_API_KEY=your-anthropic-api-key
GITHUB_TOKEN=your-github-token-optional
JWT_EXPIRES_IN=24h
BACKEND_PORT=3001
# Puerto publicado: ver docker-compose (FRONTEND_HOST_PORT, default 8080)
FRONTEND_URL=http://localhost:8080
FRONTEND_HOST_PORT=8080
LOG_LEVEL=info

# Redis
REDIS_URL=redis://redis:6379
