# ==================== BASE DE DATOS ====================
# PostgreSQL connection string
# Formato: postgresql://usuario:contraseña@localhost:5432/scr_agent
DATABASE_URL=postgresql://postgres:password@localhost:5432/scr_agent

# ==================== LLM PROVIDER ====================
# Proveedor de LLM: 'anthropic' (nube) o 'lmstudio' (local)
LLM_PROVIDER=anthropic

# --- Anthropic (nube) ---
# Obtener en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-v4-...
# Modelos por agente (opcional, usa defaults si no se especifica)
# ANTHROPIC_INSPECTOR_MODEL=claude-sonnet-4-6
# ANTHROPIC_DETECTIVE_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_FISCAL_MODEL=claude-sonnet-4-6

# --- LM Studio (local) ---
# Iniciar LM Studio → Developer → Start Server (puerto 1234 por defecto)
# LMSTUDIO_BASE_URL=http://localhost:1234/v1
# Modelo global (si no se especifica por agente)
# LMSTUDIO_MODEL=qwen2.5-coder-7b-instruct
# Modelos por agente (opcional)
# LMSTUDIO_INSPECTOR_MODEL=qwen2.5-coder-7b-instruct
# LMSTUDIO_DETECTIVE_MODEL=qwen2.5-coder-7b-instruct
# LMSTUDIO_FISCAL_MODEL=qwen2.5-coder-7b-instruct

# GitHub Token (si se usa)
# Obtener en: https://github.com/settings/tokens
GITHUB_TOKEN=ghp_...

# ==================== SEGURIDAD ====================
# JWT Secret para autenticación
# Generar con: openssl rand -base64 32
JWT_SECRET=tu-super-secreto-aqui

# Clave AES-256-GCM para encriptar tokens de GitHub en BD (32 bytes = 64 chars hex)
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# Duración del token JWT (ej. 24h, 7d)
JWT_EXPIRES_IN=24h

# Entorno (development, production)
NODE_ENV=development

# ==================== SERVIDOR ====================
# Puerto del backend
BACKEND_PORT=3000

# URL base del backend (para CORS, etc.)
BACKEND_URL=http://localhost:3000

# URL base del frontend (para CORS)
FRONTEND_URL=http://localhost:5173

# ==================== CACHE ====================
# Redis (opcional, para producción)
# REDIS_URL=redis://localhost:6379

# ==================== LOGGING ====================
# Nivel de logging (debug, info, warn, error)
LOG_LEVEL=info

# ==================== OPCIONALES ====================
# Timezones para reportes
TIMEZONE=America/Mexico_City

# Directorio de caché para clones de Git
GIT_CACHE_DIR=/tmp/scr-agent-cache

# Timeout para análisis (en minutos)
ANALYSIS_TIMEOUT=30
